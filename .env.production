# RocketLab frontend configuration.
#All keys must be
# prefixed with VITE_ to be exposed to the browser build.

# Base URL the browser uses to reach the API.
# Leave empty in dev to use the Vite proxy defined in vite.config.ts (avoids
# CORS). In production, set this to the deployed API origin, e.g.
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=https://rocketlab-api.fly.dev/

# Dev-only: where the Vite proxy forwards /telemetry and /health requests.
# Defaults to http://localhost:8000 (the FastAPI backend) when unset.
VITE_API_PROXY_TARGET=http://localhost:8000
